{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "BmmdlRegistry": ""
  },
  "Admin": {
    "Enabled": true,
    "ApiKey": ""
  },
  "Api": {
    "DefaultPageSize": 50,
    "MaxPageSize": 1000
  },
  "DeltaToken": {
    "ExpiryHours": 24
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "BMMDL.Runtime",
    "Audience": "BMMDL.Client",
    "ExpirationMinutes": 60,
    "RefreshExpirationDays": 7
  },
  "Plugins": {
    "Directory": "plugins",
    "WatchDirectory": false,
    "Bootstrap": {
      "Exclude": []
    }
  },
  "OAuth": {
    "AllowTestTokens": false,
    "Google": {
      "ClientId": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
      "Enabled": false
    },
    "Microsoft": {
      "ClientId": "",
      "TenantId": "common",
      "Enabled": false
    },
    "Apple": {
      "ServiceId": "",
      "Enabled": false
    }
  }
}