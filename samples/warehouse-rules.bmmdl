// ============================================================
// ANALYTICS VIEWS
// ============================================================

define view WarehouseKPIDashboard as
    select
        w.warehouseCode,
        w.warehouseName,
        w.usagePercent as capacityUtilization,
        w.currentPalletCount,
        w.maxPalletPositions,
        count(z.ID) as zoneCount,
        sum(case when z.usagePercent >= 90 then 1 else 0 end) as criticalZones,
        w.isReceivingActive,
        w.isShippingActive,
        w.status
    from WarehouseMaster as w
    left join WarehouseZoneMaster as z on z.ID = w.ID
    where w.status = #Active
    group by w.warehouseCode, w.warehouseName, w.usagePercent, w.currentPalletCount, 
             w.maxPalletPositions, w.isReceivingActive, w.isShippingActive, w.status

define view DailyReceivingMetrics as
    select
        gr.warehouse,
        gr.receiptDate,
        count(gr.ID) as receiptCount,
        sum(grl.quantity) as totalQuantity,
        sum(grl.damagedQty) as damagedQuantity,
        sum(grl.rejectedQty) as rejectedQuantity,
        round(sum(grl.damagedQty + grl.rejectedQty) * 100.0 / nullif(sum(grl.quantity), 0), 2) as rejectRate,
        count(distinct grl.item) as uniqueItems
    from GoodsReceipt as gr
    inner join GoodsReceiptLine as grl on grl.ID = gr.ID
    where gr.status = #Posted
    group by gr.warehouse, gr.receiptDate

define view DailyPickingMetrics as
    select
        pt.pickZone,
        pt.taskDate as pickDate,
        count(pt.ID) as taskCount,
        sum(pt.pickedQuantity) as totalPicked,
        sum(pt.shortQuantity) as totalShort,
        round(sum(pt.shortQuantity) * 100.0 / nullif(sum(pt.quantity), 0), 2) as shortRate,
        avg(pt.durationMinutes) as avgPickTimeMinutes,
        count(distinct pt.assignedTo) as pickerCount
    from PickTask as pt
    where pt.status in (#Completed, #ShortPicked)
    group by pt.pickZone, pt.taskDate

define view PutawayPerformanceMetrics as
    select
        pt.assignedTo as userId,
        count(pt.ID) as totalTasks,
        sum(pt.actualQuantity) as totalQuantity,
        avg(pt.durationMinutes) as avgDurationMinutes,
        sum(case when pt.isLocationOverridden = true then 1 else 0 end) as overrideCount,
        round(sum(case when pt.isLocationOverridden = true then 1 else 0 end) * 100.0 / count(pt.ID), 2) as overridePercent
    from PutawayTask as pt
    where pt.status = #Completed
    group by pt.assignedTo

define view PickerProductivityRanking as
    select
        pt.assignedTo as pickerId,
        count(pt.ID) as tasksCompleted,
        sum(pt.pickedQuantity) as totalPicked,
        avg(pt.durationMinutes) as avgTimeMinutes,
        round(sum(pt.pickedQuantity) / nullif(sum(pt.durationMinutes), 0) * 60, 2) as unitsPerHour,
        round(sum(pt.shortQuantity) * 100.0 / nullif(sum(pt.quantity), 0), 2) as shortPercent
    from PickTask as pt
    where pt.status in (#Completed, #ShortPicked)
      and pt.completedAt >= add_days($now, -30)
    group by pt.assignedTo
    order by unitsPerHour desc

define view InventoryAgingReport as
    select
        grl.item,
        grl.batchNumber,
        grl.targetZone,
        grl.targetBin,
        gr.receiptDate,
        grl.manufacturingDate,
        grl.expiryDate,
        DATEDIFF('day', gr.receiptDate, $today) as daysInWarehouse,
        DATEDIFF('day', $today, grl.expiryDate) as daysToExpiry,
        grl.acceptedQty as quantity,
        grl.unitCost,
        grl.totalValue,
        case 
            when DATEDIFF('day', $today, grl.expiryDate) <= 0 then 'Expired'
            when DATEDIFF('day', $today, grl.expiryDate) <= 7 then 'Critical'
            when DATEDIFF('day', $today, grl.expiryDate) <= 30 then 'Warning'
            when DATEDIFF('day', $today, grl.expiryDate) <= 90 then 'Monitor'
            else 'Normal'
        end as expiryStatus
    from GoodsReceiptLine as grl
    inner join GoodsReceipt as gr on gr.ID = grl.ID
    where gr.status = #Posted
      and grl.expiryDate is not null
    order by grl.expiryDate asc

define view ShortPickAnalysisByItem as
    select
        pt.item,
        i.itemCode,
        i.itemName,
        count(pt.ID) as shortPickCount,
        sum(pt.shortQuantity) as totalShortQty,
        sum(pt.quantity) as totalRequestedQty,
        round(sum(pt.shortQuantity) * 100.0 / sum(pt.quantity), 2) as shortRate,
        count(distinct pt.pickZone) as affectedZones
    from PickTask as pt
    inner join Item as i on i.ID = pt.item
    where pt.status = #ShortPicked
      and pt.shortQuantity > 0
    group by pt.item, i.itemCode, i.itemName
    having count(pt.ID) >= 3
    order by shortRate desc

define view OnTimeShippingMetrics as
    select
        oo.warehouse,
        oo.orderType,
        count(oo.ID) as totalOrders,
        sum(case when oo.isLate = false then 1 else 0 end) as onTimeOrders,
        sum(case when oo.isLate = true then 1 else 0 end) as lateOrders,
        round(sum(case when oo.isLate = false then 1 else 0 end) * 100.0 / count(oo.ID), 2) as onTimePercent,
        avg(oo.daysLate) as avgDaysLate,
        sum(case when oo.isShortShip = true then 1 else 0 end) as shortShipOrders,
        round(sum(case when oo.isShortShip = true then 1 else 0 end) * 100.0 / count(oo.ID), 2) as shortShipPercent
    from OutboundOrder as oo
    where oo.status in (#Shipped, #Completed)
      and oo.actualShipDate is not null
    group by oo.warehouse, oo.orderType

define view ZoneActivityHeatmap as
    select
        z.ID as zoneId,
        z.zoneCode,
        z.zoneName,
        z.zoneType,
        z.usagePercent as capacityUsage,
        coalesce(put.putawayCount, 0) as putawayCount,
        coalesce(pick.pickCount, 0) as pickCount,
        coalesce(put.putawayCount, 0) + coalesce(pick.pickCount, 0) as totalActivity,
        case 
            when coalesce(put.putawayCount, 0) + coalesce(pick.pickCount, 0) >= 100 then 'Hot'
            when coalesce(put.putawayCount, 0) + coalesce(pick.pickCount, 0) >= 50 then 'Warm'
            when coalesce(put.putawayCount, 0) + coalesce(pick.pickCount, 0) >= 10 then 'Cool'
            else 'Cold'
        end as activityLevel
    from WarehouseZoneMaster as z
    left join (
        select sourceZone, count(*) as putawayCount 
        from PutawayTask 
        where status = #Completed and completedAt >= add_days($now, -7)
        group by sourceZone
    ) as put on put.sourceZone = z.ID
    left join (
        select pickZone, count(*) as pickCount 
        from PickTask 
        where status in (#Completed, #ShortPicked) and completedAt >= add_days($now, -7)
        group by pickZone
    ) as pick on pick.pickZone = z.ID
    where z.status = #Active

// ============================================================
// WAREHOUSE ANALYTICS SERVICE
// ============================================================

@Core.Description: 'Warehouse Analytics and Reporting Service'
service WarehouseAnalyticsService {
    
    // Dashboard KPIs
    function getWarehouseKPIs(warehouseId: UUID) returns WarehouseKPISummary;
    function getOperationalDashboard(warehouseId: UUID, asOfDate: Date) returns OperationalDashboard;
    
    // Capacity analytics
    function getCapacityTrend(warehouseId: UUID, days: Integer) returns CapacityTrendReport;
    function getZoneUtilization(warehouseId: UUID) returns array<ZoneUtilizationMetric>;
    function getBinUtilization(zoneId: UUID) returns array<BinUtilizationMetric>;
    
    // Receiving analytics
    function getReceivingMetrics(warehouseId: UUID, dateFrom: Date, dateTo: Date) returns ReceivingAnalytics;
    function getVendorPerformance(warehouseId: UUID, dateFrom: Date, dateTo: Date) returns array<VendorReceivingMetric>;
    
    // Picking analytics
    function getPickingMetrics(warehouseId: UUID, dateFrom: Date, dateTo: Date) returns PickingAnalytics;
    function getPickerLeaderboard(warehouseId: UUID, dateFrom: Date, dateTo: Date) returns array<PickerRanking>;
    function getShortPickAnalysis(warehouseId: UUID, dateFrom: Date, dateTo: Date) returns ShortPickAnalysis;
    
    // Shipping analytics
    function getShippingMetrics(warehouseId: UUID, dateFrom: Date, dateTo: Date) returns ShippingAnalytics;
    function getCarrierPerformance(warehouseId: UUID, dateFrom: Date, dateTo: Date) returns array<CarrierMetric>;
    function getOnTimeDeliveryReport(warehouseId: UUID, dateFrom: Date, dateTo: Date) returns OnTimeDeliveryReport;
    
    // Inventory analytics
    function getInventoryAgingReport(warehouseId: UUID) returns InventoryAgingAnalysis;
    function getSlowMovingItems(warehouseId: UUID, thresholdDays: Integer) returns array<SlowMovingItem>;
    function getExpiringInventory(warehouseId: UUID, thresholdDays: Integer) returns array<ExpiringInventoryItem>;
    
    // Productivity analytics
    function getLaberProductivity(warehouseId: UUID, dateFrom: Date, dateTo: Date) returns LaborProductivityReport;
    function getZoneActivityHeatmap(warehouseId: UUID) returns ZoneHeatmapData;
}

// ============================================================
// ANALYTICS VALUE OBJECTS
// ============================================================

type WarehouseKPISummary : {
    warehouseId: UUID;
    warehouseCode: String(20);
    asOfDate: DateTime;
    capacityUtilization: Decimal(5, 2);
    receivingTodayCount: Integer;
    shippingTodayCount: Integer;
    openPickTasks: Integer;
    overdueOrders: Integer;
    criticalZoneCount: Integer;
    expiringItemsCount: Integer;
}

type OperationalDashboard : {
    warehouseId: UUID;
    reportDate: Date;
    receiving: ReceivingSummary;
    shipping: ShippingSummary;
    picking: PickingSummary;
    capacity: CapacitySummary;
    alerts: array<OperationalAlert>;
}

type ReceivingSummary : {
    shipmentsExpected: Integer;
    shipmentsReceived: Integer;
    linesReceived: Integer;
    quantityReceived: Decimal(18, 3);
    pendingPutaway: Integer;
}

type ShippingSummary : {
    ordersToShip: Integer;
    ordersShipped: Integer;
    linesShipped: Integer;
    quantityShipped: Decimal(18, 3);
    lateOrders: Integer;
}

type PickingSummary : {
    activeWaves: Integer;
    openTasks: Integer;
    completedTasks: Integer;
    averagePickTimeMinutes: Decimal(8, 2);
    shortPickRate: Decimal(5, 2);
}

type CapacitySummary : {
    overallUtilization: Decimal(5, 2);
    criticalZones: Integer;
    availablePositions: Integer;
    inboundPending: Integer;
}

type OperationalAlert : {
    alertType: String(50);
    alertSeverity: String(20);
    alertMessage: String(500);
    entityId: UUID;
    entityType: String(50);
    alertTimestamp: DateTime
}

type CapacityTrendReport : {
    warehouseId: UUID;
    periodStart: Date;
    periodEnd: Date;
    dailyUtilization: array<DailyCapacity>;
    averageUtilization: Decimal(5, 2);
    peakUtilization: Decimal(5, 2);
    peakDate: Date;
}

type DailyCapacity : {
    reportDate: Date;
    utilization: Decimal(5, 2);
    availablePositions: Integer;
    receivingVolume: Decimal(18, 3);
    shippingVolume: Decimal(18, 3);
}

type ZoneUtilizationMetric : {
    zoneId: UUID;
    zoneCode: String(20);
    zoneName: String(100);
    zoneType: String(50);
    utilization: Decimal(5, 2);
    usedPositions: Integer;
    totalPositions: Integer;
    activityScore: Integer;
}

type BinUtilizationMetric : {
    binId: UUID;
    binCode: String(30);
    isOccupied: Boolean;
    weightUtilization: Decimal(5, 2);
    itemCount: Integer;
    lastActivity: DateTime;
}

type ReceivingAnalytics : {
    warehouseId: UUID;
    periodStart: Date;
    periodEnd: Date;
    totalShipments: Integer;
    totalLines: Integer;
    totalQuantity: Decimal(18, 3);
    averageReceiveTimeMinutes: Decimal(8, 2);
    averagePutawayTimeMinutes: Decimal(8, 2);
    damageRate: Decimal(5, 4);
    rejectRate: Decimal(5, 4);
    onTimeArrivalRate: Decimal(5, 2);
}

type VendorReceivingMetric : {
    vendorId: UUID;
    vendorCode: String(50);
    vendorName: String(200);
    shipmentCount: Integer;
    lineCount: Integer;
    quantityReceived: Decimal(18, 3);
    damageRate: Decimal(5, 4);
    onTimeRate: Decimal(5, 2);
    qualityScore: Decimal(5, 2);
}

type PickingAnalytics : {
    warehouseId: UUID;
    periodStart: Date;
    periodEnd: Date;
    totalTasks: Integer;
    totalLinesPicked: Integer;
    totalQuantityPicked: Decimal(18, 3);
    averagePickTimeMinutes: Decimal(8, 2);
    linesPerHour: Decimal(8, 2);
    pickAccuracy: Decimal(5, 2);
    shortPickRate: Decimal(5, 2);
    activePickers: Integer;
}

type PickerRanking : {
    ranking: Integer;
    pickerId: String(100);
    pickerName: String(200);
    tasksCompleted: Integer;
    quantityPicked: Decimal(18, 3);
    averageTimeMinutes: Decimal(8, 2);
    unitsPerHour: Decimal(8, 2);
    accuracy: Decimal(5, 2);
    shortPickRate: Decimal(5, 2);
}

type ShortPickAnalysis : {
    warehouseId: UUID;
    periodStart: Date;
    periodEnd: Date;
    totalShortPicks: Integer;
    totalShortQuantity: Decimal(18, 3);
    overallShortRate: Decimal(5, 2);
    byReason: array<ShortPickReason>;
    byItem: array<ShortPickByItem>;
    byZone: array<ShortPickByZone>;
    recommendations: array<String>;
}

type ShortPickByItem : {
    itemId: UUID;
    itemCode: String(50);
    itemName: String(200);
    shortCount: Integer;
    shortQuantity: Decimal(18, 3);
    shortRate: Decimal(5, 2);
}

type ShortPickByZone : {
    zoneId: UUID;
    zoneCode: String(20);
    shortCount: Integer;
    shortQuantity: Decimal(18, 3);
    shortRate: Decimal(5, 2);
}

type ShippingAnalytics : {
    warehouseId: UUID;
    periodStart: Date;
    periodEnd: Date;
    totalOrders: Integer;
    totalLinesShipped: Integer;
    totalQuantityShipped: Decimal(18, 3);
    totalPackages: Integer;
    totalWeightKg: Decimal(12, 3);
    onTimeShipRate: Decimal(5, 2);
    shortShipRate: Decimal(5, 2);
    averageOrderProcessingMinutes: Decimal(8, 2);
}

type CarrierMetric : {
    carrier: String(100);
    shipmentCount: Integer;
    packageCount: Integer;
    totalWeightKg: Decimal(12, 3);
    onTimeDeliveryRate: Decimal(5, 2);
    averageCostPerKg: Decimal(10, 2);
    claims: Integer;
}

type OnTimeDeliveryReport : {
    warehouseId: UUID;
    periodStart: Date;
    periodEnd: Date;
    totalOrders: Integer;
    onTimeOrders: Integer;
    lateOrders: Integer;
    onTimeRate: Decimal(5, 2);
    averageDaysLate: Decimal(5, 2);
    byServiceLevel: array<ServiceLevelMetric>;
    byCarrier: array<CarrierOnTimeMetric>;
}

type ServiceLevelMetric : {
    serviceLevel: String(50);
    orderCount: Integer;
    onTimeRate: Decimal(5, 2);
}

type CarrierOnTimeMetric : {
    carrier: String(100);
    orderCount: Integer;
    onTimeRate: Decimal(5, 2);
    averageDaysLate: Decimal(5, 2);
}

type InventoryAgingAnalysis : {
    warehouseId: UUID;
    asOfDate: Date;
    totalItems: Integer;
    totalValue: Decimal(18, 2);
    agingBuckets: array<AgingBucket>;
    expiringItems: array<ExpiringInventoryItem>;
    slowMovingValue: Decimal(18, 2);
}

type AgingBucket : {
    bucketName: String(50);
    minDays: Integer;
    maxDays: Integer;
    itemCount: Integer;
    totalValue: Decimal(18, 2);
    percentOfTotal: Decimal(5, 2);
}

type ExpiringInventoryItem : {
    itemId: UUID;
    itemCode: String(50);
    itemName: String(200);
    batchNumber: String(50);
    expiryDate: Date;
    daysToExpiry: Integer;
    quantity: Decimal(18, 3);
    value: Decimal(18, 2);
    zone: String(20);
    bin: String(30);
}

type SlowMovingItem : {
    itemId: UUID;
    itemCode: String(50);
    itemName: String(200);
    lastMovementDate: Date;
    daysSinceMovement: Integer;
    currentStock: Decimal(18, 3);
    stockValue: Decimal(18, 2);
    suggestedAction: String(100);
}

type LaborProductivityReport : {
    warehouseId: UUID;
    periodStart: Date;
    periodEnd: Date;
    totalHours: Decimal(10, 2);
    receiving: LaborActivityMetric;
    putaway: LaborActivityMetric;
    picking: LaborActivityMetric;
    packing: LaborActivityMetric;
    overallUnitsPerHour: Decimal(8, 2);
}

type LaborActivityMetric : {
    activityType: String(50);
    totalTasks: Integer;
    totalUnits: Decimal(18, 3);
    totalHours: Decimal(10, 2);
    unitsPerHour: Decimal(8, 2);
    workerCount: Integer;
}

