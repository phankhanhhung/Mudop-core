// ============================================================
// BMMDL Sample: Warehouse - Business Rules & Analytics
// Advanced features: complex rules, triggers, computed analytics
// ============================================================

namespace Warehouse;

using Common;

// ============================================================
// INBOUND VALIDATION RULES
// ============================================================

rule InboundShipmentValidation for InboundShipment on before create, before update {
    // Validate vendor is active
    validate vendor.status = #Active
        message 'Vendor must be active to create shipments'
        severity error;
    
    // Validate warehouse is receiving
    validate warehouse.status = #Active
        message 'Warehouse must be active'
        severity error;
    
    // Validate has lines
    validate count(lines) > 0
        message 'Shipment must have at least one line'
        severity error;
    
    // Validate expected arrival is in future for new shipments
    when status = #Draft then {
        validate expectedArrivalDate >= $today
            message 'Expected arrival date must be today or in the future'
            severity warning;
    }
}

rule InboundShipmentWeightValidation for InboundShipment on before update {
    // Validate net weight doesn't exceed gross weight
    when grossWeightKg is not null and netWeightKg is not null then {
        validate netWeightKg <= grossWeightKg
            message 'Net weight cannot exceed gross weight'
            severity error;
    }
}

rule InboundLineExpiryValidation for InboundShipmentLine on before create, before update {
    // Validate expiry date is after manufacturing date
    when expiryDate is not null and manufacturingDate is not null then {
        validate expiryDate > manufacturingDate
            message 'Expiry date must be after manufacturing date'
            severity error;
    }
    
    // Warn if item is close to expiry
    when expiryDate is not null then {
        when DATEDIFF('day', $today, expiryDate) < 30 then {
            validate false
                message 'Warning: Item expires within 30 days'
                severity warning;
        }
    }
    
    // Auto-flag for inspection if hazmat
    when item.isHazmat = true then {
        compute requiresInspection = true;
        compute inspectionStatus = #Pending;
    }
}

// ============================================================
// GOODS RECEIPT RULES
// ============================================================

rule GoodsReceiptCalculation for GoodsReceiptLine on before create, before update {
    // Calculate accepted quantity
    compute acceptedQty = quantity - damagedQty - rejectedQty;
    
    // Calculate total value
    compute totalValue = acceptedQty * unitCost;
    
    // Auto-set inspection for specific item categories
    when item.itemCategory.requiresInspection = true then {
        compute requiresInspection = true;
    }
    
    // Auto-set inspection for cold chain items
    when item.requiresColdChain = true then {
        compute requiresInspection = true;
    }
}

rule GoodsReceiptPosting for GoodsReceipt on before update {
    // Validate all lines are processed before posting
    when $old.status = #Draft and status = #Posted then {
        validate allLinesProcessed = true
            message 'All lines must be processed before posting'
            severity error;
        
        // Validate no pending inspections
        validate allInspectionsComplete = true
            message 'All required inspections must be completed before posting'
            severity error;
        
        // Set posted timestamp
        compute postedAt = $now;
    }
}

// ============================================================
// PUTAWAY RULES
// ============================================================

rule PutawayTaskValidation for PutawayTask on before create {
    // Validate source bin has the item
    validate sourceBin.isOccupied = true
        message 'Source bin is empty'
        severity error;
    
    // Validate target bin can accept item
    when suggestedBin.fixedItemId is not null then {
        validate suggestedBin.fixedItemId = item.ID
            message 'Target bin is assigned to a different item'
            severity error;
    }
    
    // Validate target bin is not blocked
    validate suggestedBin.status != #Blocked and suggestedBin.status != #Damaged
        message 'Target bin is not available'
        severity error;
}

rule PutawayLocationSuggestion for PutawayTask on before create {
    // Auto-suggest zone based on item category
    when suggestedZone is null then {
        // Hazmat items go to hazmat zone
        when item.isHazmat = true then {
            // Logic would select first hazmat zone
        }
        
        // Cold chain items go to temperature controlled zone
        when item.requiresColdChain = true then {
            // Logic would select appropriate temp zone
        }
    }
}

rule PutawayCompletion for PutawayTask on after update {
    // Update bin status when putaway completed
    when $old.status != #Completed and status = #Completed then {
        // Update source bin
        compute sourceBin.currentItemCount = sourceBin.currentItemCount - 1;
        when sourceBin.currentItemCount <= 0 then {
            compute sourceBin.isOccupied = false;
            compute sourceBin.status = #Available;
        }
        
        // Update target bin
        compute actualBin.isOccupied = true;
        compute actualBin.currentItemCount = actualBin.currentItemCount + 1;
        compute actualBin.currentWeightKg = actualBin.currentWeightKg + (actualQuantity * item.unitWeightKg);
    }
}

// ============================================================
// OUTBOUND ORDER RULES
// ============================================================

rule OutboundOrderValidation for OutboundOrder on before create, before update {
    // Validate warehouse is shipping
    when status = #Released then {
        validate warehouse.isShippingActive = true
            message 'Warehouse shipping is currently disabled'
            severity error;
    }
    
    // Validate has lines
    validate count(lines) > 0
        message 'Order must have at least one line'
        severity error;
    
    // Validate required ship date
    when requiredShipDate is not null and promisedDeliveryDate is not null then {
        validate promisedDeliveryDate >= requiredShipDate
            message 'Promised delivery cannot be before required ship date'
            severity warning;
    }
}

rule OutboundOrderCalculation for OutboundOrder on before create, before update {
    // Calculate totals
    compute lineCount = count(lines);
    compute totalOrderedQty = sum(lines.orderedQty);
    compute totalAllocatedQty = sum(lines.allocatedQty);
    compute totalPickedQty = sum(lines.pickedQty);
    compute totalShippedQty = sum(lines.shippedQty);
    compute totalWeightKg = sum(lines.lineWeightKg);
    compute totalVolumeCubicM = sum(lines.lineVolumeCubicM);
}

rule OutboundOrderStatusTransition for OutboundOrder on before update {
    // Validate status transitions
    when $old.status = #Open and status = #Released then {
        validate count(lines) > 0
            message 'Cannot release order with no lines'
            severity error;
        
        compute releasedAt = $now;
    }
    
    when $old.status = #Released and status = #Allocated then {
        validate allocationPercent > 0
            message 'Order must have some allocation before marking as allocated'
            severity error;
        
        compute allocatedAt = $now;
    }
    
    // Cannot go backwards from picked
    when $old.status = #Picked and status in (#Open, #Released, #Allocated) then {
        validate false
            message 'Cannot revert order from Picked status'
            severity error;
    }
    
    // Shipped to open not allowed
    when $old.status = #Shipped and status != #Completed then {
        validate false
            message 'Shipped orders can only be marked as Completed'
            severity error;
    }
}

rule OutboundLineCalculation for OutboundOrderLine on before create, before update {
    // Calculate weight and volume
    when item.unitWeightKg is not null then {
        compute unitWeightKg = item.unitWeightKg;
        compute lineWeightKg = orderedQty * unitWeightKg;
    }
    
    when item.unitVolumeCubicM is not null then {
        compute unitVolumeCubicM = item.unitVolumeCubicM;
        compute lineVolumeCubicM = orderedQty * unitVolumeCubicM;
    }
}

// ============================================================
// PICK WAVE RULES
// ============================================================

rule WaveValidation for PickWave on before create, before update {
    // Validate warehouse is active
    validate warehouse.status = #Active
        message 'Warehouse must be active'
        severity error;
}

rule WaveCalculation for PickWave on before create, before update {
    // Calculate metrics
    compute orderCount = count(orders);
    compute totalLines = sum(orders.lineCount);
    compute totalQuantity = sum(orders.totalOrderedQty);
    compute totalPickedQty = sum(orders.totalPickedQty);
    compute pickTaskCount = count(pickTasks);
    compute completedTaskCount = sum(case when pickTasks.status = #Completed then 1 else 0 end);
}

rule WaveRelease for PickWave on before update {
    // Validate before release
    when $old.status = #Draft and status = #Released then {
        validate orderCount > 0
            message 'Wave must have at least one order'
            severity error;
        
        // Auto-generate pick tasks on release
        compute releasedAt = $now;
    }
}

rule WaveCompletion for PickWave on after update {
    // Update order statuses when wave completes
    when $old.status = #InProgress and status = #Completed then {
        // All orders in wave should be marked as Picked
        // This would typically trigger updates to child orders
    }
}

// ============================================================
// PICK TASK RULES
// ============================================================

rule PickTaskValidation for PickTask on before create {
    // Validate bin has stock
    validate pickBin.isOccupied = true
        message 'Pick bin is empty'
        severity error;
    
    // Validate bin is not blocked
    validate pickBin.status != #Blocked
        message 'Pick bin is blocked'
        severity error;
}

rule PickTaskAssignment for PickTask on before update {
    // Validate assignment
    when $old.status = #Open and status = #Assigned then {
        validate assignedTo is not null
            message 'Task must be assigned to a picker'
            severity error;
        
        compute assignedAt = $now;
    }
}

rule PickTaskCompletion for PickTask on after update {
    // Update inventory when pick completed
    when $old.status = #InProgress and status in (#Completed, #ShortPicked) then {
        // Reduce bin quantity
        compute pickBin.currentItemCount = pickBin.currentItemCount - 1;
        
        // Update order line picked quantity
        when outboundOrderLine is not null then {
            compute outboundOrderLine.pickedQty = outboundOrderLine.pickedQty + pickedQuantity;
            when shortQuantity > 0 then {
                compute outboundOrderLine.shortQty = outboundOrderLine.shortQty + shortQuantity;
                compute outboundOrderLine.status = #ShortPicked;
            }
        }
        
        // Mark bin as available if empty
        when pickBin.currentItemCount <= 0 then {
            compute pickBin.isOccupied = false;
            compute pickBin.status = #Available;
        }
    }
}

rule PickShortageTracking for PickTask on after update {
    // Alert on short picks
    when status = #ShortPicked and shortQuantity > 0 then {
        // Trigger replenishment analysis
        // Call InventoryService.CheckReplenishment(item.ID, pickZone.ID)
    }
}

// ============================================================
// WAREHOUSE CAPACITY RULES
// ============================================================

rule WarehouseCapacityMonitoring for WarehouseMaster on after update {
    // Alert when nearing capacity
    when usagePercent >= 85 and $old.usagePercent < 85 then {
        call NotificationService.SendCapacityAlert(ID, warehouseCode, usagePercent);
    }
    
    // Critical alert when over 95%
    when usagePercent >= 95 and $old.usagePercent < 95 then {
        call NotificationService.SendCriticalCapacityAlert(ID, warehouseCode, usagePercent);
    }
}

rule ZoneCapacityMonitoring for WarehouseZoneMaster on after update {
    // Update parent warehouse pallet count
    when currentPalletCount != $old.currentPalletCount then {
        // Recalculate warehouse totals
    }
    
    // Alert when zone is near capacity
    when usagePercent >= 90 and $old.usagePercent < 90 then {
        call NotificationService.SendZoneCapacityAlert(ID, zoneCode, usagePercent);
    }
    
    // Auto-mark zone as full
    when usagePercent >= 98 then {
        compute status = #Full;
    }
}

rule BinWeightValidation for BinLocationMaster on before update {
    // Prevent overweight conditions
    when currentWeightKg > maxWeightKg then {
        validate false
            message 'Bin weight limit exceeded'
            severity warning;
    }
}

// ============================================================
// INVENTORY AGING RULES
// ============================================================

rule ExpiryDateMonitoring for GoodsReceiptLine on after create {
    // Flag items expiring soon
    when expiryDate is not null then {
        when DATEDIFF('day', $today, expiryDate) <= 30 then {
            call NotificationService.SendExpiryWarning(item.ID, batchNumber, expiryDate, 30);
        }
        
        when DATEDIFF('day', $today, expiryDate) <= 7 then {
            call NotificationService.SendUrgentExpiryAlert(item.ID, batchNumber, expiryDate, 7);
        }
    }
}

